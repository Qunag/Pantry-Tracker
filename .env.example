# ── Database ──────────────────────────────────────────────
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_strong_password
POSTGRES_DB=food_expiry_db

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=change-this-secret-before-deploy
JWT_EXPIRES_IN=7d

# ── Email (để trống = dùng Ethereal SMTP giả cho dev) ─────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=Food Expiry Tracker <noreply@foodtracker.com>

# ── Frontend ──────────────────────────────────────────────
# Khi chạy Docker: đổi thành tên domain/IP thật nếu deploy
NEXT_PUBLIC_API_URL=http://localhost:3000
