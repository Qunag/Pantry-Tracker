# PostgreSQL (dùng cho docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=food_expiry_db

# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/food_expiry_db?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV=development

# Email (Ethereal for dev - auto-generated, or real Gmail)
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=your_ethereal_user@ethereal.email
EMAIL_PASS=your_ethereal_password
EMAIL_FROM="Food Expiry Tracker <noreply@foodtracker.com>"
